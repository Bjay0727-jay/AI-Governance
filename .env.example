# ============================================================================
# ForgeAI Govern™ - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the required values.
# NEVER commit .env to version control.
# ============================================================================

# --- Required ---

# JWT signing secret (minimum 32 characters). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# --- Optional ---

# Server port (default: 3000)
PORT=3000

# Environment name (default: local)
NODE_ENV=local

# CORS allowed origins (comma-separated, default: http://localhost:3000)
CORS_ORIGIN=http://localhost:3000

# Database path for local development (default: ./data/forgeai.db)
# DB_PATH=./data/forgeai.db

# ============================================================================
# Cloudflare Workers Configuration (for wrangler deploy)
# ============================================================================
# These are set via `wrangler secret put <NAME>` for production, not in .env.
#
# CLOUDFLARE_API_TOKEN=     # CI/CD deployment token
# CLOUDFLARE_ACCOUNT_ID=    # Cloudflare account ID
